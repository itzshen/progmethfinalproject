<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TabPane?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="game.ui.GameController"
           stylesheets="@style.css">

    <!-- LAYER 1: Game World -->
    <Pane style="-fx-background-color: #111111;">
        <Canvas fx:id="gameCanvas" width="2000.0" height="2000.0"/>
    </Pane>

    <!-- LAYER 2: HUD -->
    <BorderPane pickOnBounds="false">

        <!-- Top: money bar -->
        <top>
            <HBox alignment="CENTER_LEFT" spacing="12.0"
                  style="-fx-background-color: #1a1a1a; -fx-padding: 10 14 10 14;">
                <Label fx:id="moneyLabel" text="Balance: $500"
                       style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            </HBox>
        </top>

        <!-- Bottom: inventory bar + button row -->
        <bottom>
            <VBox>

                <!--
                    Inventory bar — hidden until B is pressed.
                    Left side: Build / Remove mode buttons.
                    Right side: tabbed tile pane (fills remaining width).
                -->
                <HBox fx:id="inventoryBar"
                      visible="false"
                      managed="false"
                      prefHeight="130"
                      style="-fx-background-color: #1a1a2e; -fx-border-color: #2a4a6a; -fx-border-width: 1 0 0 0;">

                    <!-- Mode buttons — left panel -->
                    <VBox alignment="CENTER" spacing="6"
                          style="-fx-padding: 8 10 8 10; -fx-background-color: #0f1421; -fx-border-color: #2a4a6a; -fx-border-width: 0 1 0 0;">
                        <Button fx:id="buildModeButton"
                                mnemonicParsing="false"
                                text="Build&#10;[1]"
                                onAction="#setBuildMode"
                                prefWidth="64" prefHeight="50"
                                styleClass="mode-btn,mode-btn-active"/>
                        <Button fx:id="removeModeButton"
                                mnemonicParsing="false"
                                text="Remove&#10;[2]"
                                onAction="#setRemoveMode"
                                prefWidth="64" prefHeight="50"
                                styleClass="mode-btn"/>
                    </VBox>

                    <!-- Inventory tab pane — fills remaining width -->
                    <TabPane fx:id="inventoryTabPane"
                             tabClosingPolicy="UNAVAILABLE"
                             HBox.hgrow="ALWAYS"
                             style="-fx-background-color: transparent;"/>

                </HBox>

                <!-- Always-visible button row -->
                <HBox alignment="CENTER_RIGHT" spacing="10.0"
                      style="-fx-background-color: rgba(0,0,0,0.5); -fx-padding: 8 12 8 12;">
                    <Button mnemonicParsing="false" text="Inventory (B)" onAction="#toggleInventory"
                            style="-fx-background-color: #27ae60;"/>
                    <Button mnemonicParsing="false" text="Shop (E)" onAction="#toggleShop"/>
                </HBox>

            </VBox>
        </bottom>

    </BorderPane>

    <!-- LAYER 3: Shop Popup -->
    <VBox fx:id="shopPopup" visible="false" maxWidth="600.0" maxHeight="400.0"
          StackPane.alignment="CENTER"
          style="-fx-background-color: #2c3e50; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 20, 0, 0, 0); -fx-padding: 14;">
        <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 0 0 10 0;">
            <Label text="Shop" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Button mnemonicParsing="false" text="Close" onAction="#toggleShop"
                    style="-fx-background-color: #444; -fx-text-fill: white;"/>
        </HBox>

        <TabPane fx:id="shopTabPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS"/>

    </VBox>

</StackPane>
